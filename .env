# Banco de Dados (Supabase/PostgreSQL)
# Substitua pela sua string de conexão: postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# Configuração do Servidor
PORT=5000
NODE_ENV=development

# Segredo para autenticação (gere um novo para produção)
SESSION_SECRET=dev_secret_123
